meta {
  name: Create FUT Test Case via Form
  type: http
  seq: 1
}

post {
  url: {{base-url}}/api/v1/tdb/upload/form
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
      "precondition": "User must be logged in2",
      "test_type": "Inspection",
      "key_feature": "Login functionality",
      "scenario": "User enters valid credentials",
      "scenario_type": "negative",
      "platform_id": [
          1,
          2
      ],
      "channel_id": [
          1
      ],
      "code": "TDB-1",
      "test_case_step": [
          "Step 1",
          "Step 2",
          "Step 3"
      ]
  }
}

settings {
  encodeUrl: true
}

example {
  name: 201 OK
  
  request: {
    url: {{base-url}}/api/v1/tdb/upload/form
    method: POST
    mode: json
    body:json: {
      {
          "precondition": "User must be logged in2",
          "test_type": "Inspection",
          "key_feature": "Login functionality",
          "scenario": "User enters valid credentials",
          "scenario_type": "negative",
          "platform_id": [
              1,
              2
          ],
          "channel_id": [
              1
          ],
          "code": "TDB-1",
          "test_case_step": [
              "Step 1",
              "Step 2",
              "Step 3"
          ]
      }
    }
  }
  
  response: {
    headers: {
