meta {
  name: List
  type: http
  seq: 2
}

get {
  url: {{base-url}}/api/v1/tdb?page=1&sort_direction=desc&sort_by=created_at&page_size=100
  body: none
  auth: bearer
}

params:query {
  page: 1
  sort_direction: desc
  sort_by: created_at
  page_size: 100
  ~code: 
  ~key_feature: 
  ~status: 
  ~scenario: 
  ~scenario_type: 
  ~channel: 
  ~pic: 
}

auth:bearer {
  token: {{accessToken}}
}

settings {
  encodeUrl: true
}

example {
  name: 200 - Empty Data
  
  request: {
    url: {{base-url}}/api/v1/tasks/:task_id/test-cases
    method: GET
    mode: none
    params:path: {
      task_id: 1
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    body: {
      type: json
      content: '''
        {
            "process_time": "115ms",
            "status": "success",
            "code": "",
            "message": "Successfully retrieved task testcases",
            "data": {
                "list": [],
                "count": 0
            }
        }
      '''
    }
  }
}

