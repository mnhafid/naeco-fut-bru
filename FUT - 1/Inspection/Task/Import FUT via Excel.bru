meta {
  name: Import FUT via Excel
  type: http
  seq: 4
}

post {
  url: {{base-url}}/api/v1/inspections/tasks/upload/excel
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:multipart-form {
  file: @file(/Users/hafidhidayatullah/Downloads/task INSP (1).xlsx)
}

settings {
  encodeUrl: true
}

example {
  name: Success
  
  request: {
    url: {{base-url}}/api/v1/tasks/upload/excel
    method: POST
    mode: multipartForm
    body:multipart-form: {
      file: @file(/Users/adriansetiyadi/Downloads/[Template] Import Task - FUT.xlsx)
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    body: {
      type: json
      content: '''
        {
            "process_time": "373ms",
            "status": "success",
            "code": "",
            "message": "Excel import completed",
            "data": {
                "success_count": 3,
                "error_count": 0,
                "error_excel":"" // base64
            }
        }
      '''
    }
  }
}

example {
  name: Failed
  
  request: {
    url: {{base-url}}/api/v1/tasks/upload/excel
    method: POST
    mode: multipartForm
    headers: {
      : 
    }
  
    body:multipart-form: {
      file: @file(/Users/adriansetiyadi/Downloads/[Template] Import Task - FUT.xlsx)
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    body: {
      type: json
      content: '''
        {
            "process_time": "55ms",
            "status": "success",
            "code": "",
            "message": "Excel import completed",
            "data": {
                "success_count": 0,
                "error_count": 3,
                "error_excel": ""
            }
        }
      '''
    }
  }
}
