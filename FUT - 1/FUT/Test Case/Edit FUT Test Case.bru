meta {
  name: Edit FUT Test Case
  type: http
  seq: 3
}

put {
  url: {{base-url}}/api/v1/inspections/tasks/:task_id/test-cases/:id
  body: json
  auth: bearer
}

params:query {
  ~":task_id": 
}

params:path {
  task_id: 9d3a99e9-4213-4b5b-bc68-7b71bcd29114
  id: 92a740dc-73b0-442c-9548-d64f166537ff
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "precondition": "Edit User must be logged in Adrian",
    "key_feature": "Login functionality",
    "scenario": "User enters valid credentials",
    "scenario_type": "positive",
    "platform_id": [1, 2],
    "channel_id": [3],
    "test_data": "username: testuser, password: testpass",
    "status": "passed",
    "expected_result": "User is redirected to dashboard",
    "pic": "John Doe",
    "tester_notes": "Test passed without issues",
    "test_case_step": [
      "Navigate to login page",
      "Enter username and password",
      "Click login button",
      "Verify dashboard is displayed"
    ]
  }
  
}

settings {
  encodeUrl: true
}

example {
  name: 200 OK
  
  request: {
    url: {{base-url}}/api/v1/tasks/:task_id/test-cases/:id
    method: PUT
    mode: json
    params:query: {
      ~":task_id": null
    }
  
    params:path: {
      task_id: 9d3a99e9-4213-4b5b-bc68-7b71bcd29114
      id: 92a740dc-73b0-442c-9548-d64f166537ff
    }
  
    headers: {
      Content-Type: application/json
    }
  
    body:json: {
      {
        "precondition": "Edit User must be logged in Adrian",
        "key_feature": "Login functionality",
        "scenario": "User enters valid credentials",
        "scenario_type": "positive",
        "platform_id": [1, 2],
        "channel_id": [3],
        "test_data": "username: testuser, password: testpass",
        "status": "passed",
        "expected_result": "User is redirected to dashboard",
        "pic": "John Doe",
        "tester_notes": "Test passed without issues",
        "test_case_step": [
          "Navigate to login page",
          "Enter username and password",
          "Click login button",
          "Verify dashboard is displayed"
        ]
      }
      
    }
  }
  
  response: {
    headers: {
      Content-Type: application/json
    }
  
    body: {
      type: json
      content: '''
        {
            "process_time": "576ms",
            "status": "success",
            "code": "",
            "message": "Successfully updated test case"
        }`
      '''
    }
  }
}

tests {
  test("status code is 200 or 201", function() {
      expect(res.getStatus()).to.be.oneOf([200, 201]);
  });
}
